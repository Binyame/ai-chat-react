# Elastic Beanstalk configuration for Node.js backend
# This tells EB how to run your Express server

option_settings:
  aws:elasticbeanstalk:container:nodejs:
    NodeCommand: "npm start"
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
